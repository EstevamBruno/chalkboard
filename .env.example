# MySQL connection string used by Prisma
DATABASE_URL="mysql://root@localhost:3306/chalkboard"

# Secret used to sign bearer (JWT) tokens — set to a long random value
JWT_SECRET="change-me-to-a-long-random-secret"

# Token lifetime
JWT_EXPIRES_IN="7d"

# Port the combined Next.js + Socket.IO server listens on
PORT=3000
